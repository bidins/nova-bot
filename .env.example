# --- Nova piekļuve (OBLIGĀTI) ---
# UZMANĪBU: šim kontam JĀBŪT iekļautam Nova gate() sarakstā, citādi dabū 403.
NOVA_BASE=https://www.martinsbidins.com/nova
NOVA_EMAIL=
NOVA_PASSWORD=

# --- Drošība / uzvedība ---
DRY_RUN=0                     # 1 = neklikšķina "Run Action" (drošs tests)
EXPIRY_POLICY=extend          # ja kurss jau ir: extend (tikai pagarināt) | overwrite | skip
ALLOWED_LOCALES=lv            # apstrādā tikai šīs pircēja valodas (customer_locale). Tukšs = visas.
SHOPIFY_WEBHOOK_SECRET=       # Shopify webhook signing secret (HMAC). Tukšs = pārbaude izslēgta.
RETRY_INTERVAL_MIN=30         # cik bieži pārbaudīt pending klientus (minūtes)
PENDING_MAX_DAYS=30           # cik ilgi turēt neregistrētu klientu rindā
# QUEUE_FILE=/data/pending.json   # noturīgai rindai norādi uz Railway Volume

# --- E-pasts (SMTP) — vajadzīgs klienta atgādinājumiem un admin ziņām ---
SMTP_HOST=                   # piem. smtp.gmail.com | smtp.sendgrid.net | smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=0                # 1 ja ports 465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=                   # piem. "Mārtiņš Bidiņš <info@martinsbidins.com>"
ADMIN_EMAIL=                 # kur sūtīt bota statusa ziņas

# --- Klienta atgādinājumi (neregistrētiem pircējiem) ---
REMINDER_ENABLED=0           # 1 = sūta klientam "izveido kontu" e-pastu (vajag SMTP)
REMINDER_INTERVAL_HOURS=24   # cik bieži atgādināt vienam klientam
REMINDER_MAX=5               # cik atgādinājumu maksimāli vienam klientam
REGISTER_URL=https://www.martinsbidins.com/lv/register  # "Reģistrēties" pogai (atgādinājumā)
COURSES_URL=https://www.martinsbidins.com/lv/login     # "Uz maniem kursiem" pogai (kad pieslēgti)

# --- Paziņojumi: WhatsApp caur Twilio (neobligāti) ---
TWILIO_SID=
TWILIO_TOKEN=
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=                 # piem. whatsapp:+3712xxxxxxx
